APP_NAME="TGBot Seller Loyalty"
APP_ENV=local
DEBUG=true

DATABASE_URL=postgresql+asyncpg://loyalty:loyalty@db:5432/loyalty
TEST_DATABASE_URL=postgresql+asyncpg://loyalty:loyalty@localhost:5432/loyalty_test

BOT_TOKEN=123456:replace-me
BOT_USERNAME=your_bot_username
WEBHOOK_BASE_URL=https://example.com
TELEGRAM_WEBHOOK_SECRET=change-this-secret

SECRET_KEY=change-this-signing-secret
ADMIN_PASSWORD=change-this-admin-password
ADMIN_SESSION_COOKIE=loyalty_admin
WEB_SESSION_COOKIE=loyalty_session
CONSENT_VERSION=2026-06-02
UPLOAD_DIR=app/static/uploads
SESSION_TTL_HOURS=720

DEFAULT_EARN_PERCENT=5
MAX_REDEEM_PERCENT=50
POINT_TTL_DAYS=365
QR_TIMEZONE=Europe/Moscow
SELLER_TELEGRAM_IDS=

# Local HTTPS (self-signed cert). Required for phone access via https://YOUR_IP:8443
# CERT_EXTRA_IP=192.168.1.161
# CERT_DAYS=825
